---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-left">
      <a href="/" class="footer-logo">the downforce blog</a>
      <p class="footer-tagline">race analysis. actual opinions.</p>
    </div>

    <div class="footer-right">
      <nav class="footer-nav" aria-label="Footer navigation">
        <a href="/posts" class="footer-link">posts</a>
        <a href="/about" class="footer-link">about</a>
        <a href="/rss.xml" class="footer-link">rss</a>
      </nav>
      <p class="footer-copy">&copy; {year}</p>
    </div>
  </div>

  <div class="footer-flag" aria-hidden="true">
    <div class="flag-stripe"></div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--bg-dark);
    color: var(--text-light);
    margin-top: 6rem;
    overflow: hidden;
  }

  .footer-inner {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding-top: 3rem;
    padding-bottom: 2.5rem;
    gap: 2rem;
  }

  @media (max-width: 600px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  .footer-logo {
    display: block;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-light);
    letter-spacing: 0.01em;
    margin-bottom: 0.4rem;
    transition: color 0.2s ease;
  }
  .footer-logo:hover { color: var(--amber); }

  .footer-tagline {
    font-size: 0.8125rem;
    color: var(--text-light-muted);
    font-weight: 300;
    letter-spacing: 0.06em;
  }

  .footer-right {
    text-align: right;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
  }

  @media (max-width: 600px) {
    .footer-right {
      text-align: left;
      align-items: flex-start;
    }
  }

  .footer-nav {
    display: flex;
    gap: 1.5rem;
  }

  .footer-link {
    font-size: 0.8125rem;
    color: var(--text-light-muted);
    letter-spacing: 0.04em;
    text-transform: lowercase;
    transition: color 0.2s ease;
  }
  .footer-link:hover { color: var(--text-light); }

  .footer-copy {
    font-size: 0.75rem;
    color: rgba(243, 237, 225, 0.25);
    letter-spacing: 0.04em;
  }

  /* Decorative checkered stripe at the very bottom */
  .footer-flag { height: 8px; display: flex; }
  .flag-stripe {
    flex: 1;
    background-image: repeating-linear-gradient(
      90deg,
      rgba(243,237,225,0.15) 0px,
      rgba(243,237,225,0.15) 8px,
      transparent 8px,
      transparent 16px
    );
  }
</style>
