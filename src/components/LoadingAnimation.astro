---
---

<div id="page-loader" aria-hidden="true">
  <div class="loader-grid"></div>

  <div class="lights-gantry">
    <div class="gantry-bar"></div>
    <div class="lights-row">
      <div class="light-pod" data-n="1"><span class="bulb"></span></div>
      <div class="light-pod" data-n="2"><span class="bulb"></span></div>
      <div class="light-pod" data-n="3"><span class="bulb"></span></div>
      <div class="light-pod" data-n="4"><span class="bulb"></span></div>
      <div class="light-pod" data-n="5"><span class="bulb"></span></div>
    </div>
    <div class="gantry-bar"></div>
  </div>

  <div class="loader-content">
    <div class="loader-wordmark">
      <span class="wm-the">the</span>
      <span class="wm-df">downforce</span>
      <span class="wm-blog">blog</span>
    </div>
    <div class="loader-underline"></div>
    <p class="loader-tagline">race analysis · actual opinions</p>
  </div>

  <div class="speed-lines" aria-hidden="true">
    {Array.from({ length: 14 }).map((_, i) => (
      <div class="speed-line" style={`--i:${i}`}></div>
    ))}
  </div>

  <div class="loader-corner-tl">F1 · 2025</div>
  <div class="loader-corner-br">the downforce blog</div>
</div>

<style>
  #page-loader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #1B3A26;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    gap: 2.5rem;
  }

  #page-loader.loader-exit {
    animation: loaderExit 0.75s cubic-bezier(0.76, 0, 0.24, 1) forwards;
  }

  @keyframes loaderExit {
    to { transform: translateX(100%); opacity: 0.6; }
  }

  .loader-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(243,237,225,0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(243,237,225,0.035) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  .speed-lines {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .speed-line {
    position: absolute;
    left: -30%;
    height: 1px;
    top: calc(15% + var(--i) * 5.2%);
    width: 0;
    background: linear-gradient(90deg, transparent, rgba(194,84,40,0.55), rgba(194,84,40,0.2), transparent);
    animation: speedLine 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(1.58s + var(--i) * 0.025s);
  }

  @keyframes speedLine {
    to { width: 160%; }
  }

  .loader-corner-tl {
    position: absolute;
    top: 1.5rem;
    left: 1.75rem;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(243,237,225,0.2);
    opacity: 0;
    animation: fadeIn 0.5s ease 0.1s forwards;
  }

  .loader-corner-br {
    position: absolute;
    bottom: 1.5rem;
    right: 1.75rem;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: lowercase;
    color: rgba(243,237,225,0.2);
    opacity: 0;
    animation: fadeIn 0.5s ease 0.2s forwards;
  }

  @keyframes fadeIn {
    to { opacity: 1; }
  }

  .lights-gantry {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    position: relative;
    z-index: 1;
  }

  .gantry-bar {
    width: 380px;
    max-width: 90vw;
    height: 3px;
    background: linear-gradient(90deg, transparent, rgba(243,237,225,0.18), transparent);
    opacity: 0;
    animation: fadeIn 0.4s ease 0.05s forwards;
  }

  .lights-row {
    display: flex;
    gap: 1.25rem;
    align-items: center;
    padding: 0.75rem 1.5rem;
    background: rgba(0,0,0,0.4);
    border: 1px solid rgba(243,237,225,0.08);
    border-radius: 4px;
    box-shadow: inset 0 1px 0 rgba(243,237,225,0.05);
  }

  .light-pod {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: rgba(0,0,0,0.65);
    border: 2px solid rgba(243,237,225,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transform: scale(0);
    opacity: 0;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .light-pod[data-n="1"] { animation: podIn 0.3s cubic-bezier(0.34,1.56,0.64,1) 0.15s forwards; }
  .light-pod[data-n="2"] { animation: podIn 0.3s cubic-bezier(0.34,1.56,0.64,1) 0.33s forwards; }
  .light-pod[data-n="3"] { animation: podIn 0.3s cubic-bezier(0.34,1.56,0.64,1) 0.51s forwards; }
  .light-pod[data-n="4"] { animation: podIn 0.3s cubic-bezier(0.34,1.56,0.64,1) 0.69s forwards; }
  .light-pod[data-n="5"] { animation: podIn 0.3s cubic-bezier(0.34,1.56,0.64,1) 0.87s forwards; }

  @keyframes podIn {
    to { transform: scale(1); opacity: 1; }
  }

  .bulb {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: #1a0000;
    display: block;
    transition: background 0.12s ease, box-shadow 0.12s ease;
  }

  .light-pod.lit .bulb {
    background: radial-gradient(circle at 38% 32%, #ff7070, #cc0000 60%, #900000);
    box-shadow:
      0 0 8px rgba(220,0,0,1),
      0 0 20px rgba(200,0,0,0.8),
      0 0 50px rgba(180,0,0,0.45);
  }

  .light-pod.lit {
    border-color: rgba(255,80,80,0.35);
    box-shadow: 0 0 28px rgba(200,0,0,0.3);
  }

  .lights-out .light-pod {
    animation: lightsOut 0.22s cubic-bezier(0.55,0,1,0.45) forwards !important;
  }

  @keyframes lightsOut {
    to { transform: scale(0.25); opacity: 0; filter: blur(8px); }
  }

  /* ── content ── */
  .loader-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    position: relative;
    z-index: 1;
  }

  .loader-wordmark {
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1;
    opacity: 0;
    transform: translateY(-28px);
  }

  .loader-wordmark.slam {
    animation: wordmarkSlam 0.5s cubic-bezier(0.22,1,0.36,1) forwards;
  }

  @keyframes wordmarkSlam {
    to { opacity: 1; transform: translateY(0); }
  }

  .wm-the {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(0.9rem, 2.5vw, 1.25rem);
    font-weight: 400;
    color: rgba(243,237,225,0.45);
    letter-spacing: 0.28em;
    text-transform: lowercase;
  }

  .wm-df {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(3rem, 11vw, 6.5rem);
    font-weight: 800;
    color: #F3EDE1;
    letter-spacing: -0.025em;
    text-transform: lowercase;
    line-height: 0.88;
  }

  .wm-blog {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(1.6rem, 4.5vw, 3rem);
    font-weight: 400;
    font-style: italic;
    color: rgba(243,237,225,0.55);
    letter-spacing: 0.07em;
    text-transform: lowercase;
  }

  .loader-underline {
    width: 0;
    height: 2px;
    background: #C25428;
  }

  .loader-underline.draw {
    animation: drawLine 0.45s cubic-bezier(0.22,1,0.36,1) forwards;
  }

  @keyframes drawLine {
    to { width: clamp(140px, 28vw, 260px); }
  }

  .loader-tagline {
    font-family: 'Jost', sans-serif;
    font-size: clamp(0.65rem, 1.8vw, 0.85rem);
    font-weight: 300;
    color: rgba(243,237,225,0.38);
    letter-spacing: 0.2em;
    text-transform: lowercase;
    opacity: 0;
  }

  .loader-tagline.fade {
    animation: fadeIn 0.5s ease forwards;
  }
</style>

<script>
  const loader = document.getElementById('page-loader');

  if (loader) {
    const pods = loader.querySelectorAll<HTMLElement>('.light-pod');
    const gantry = loader.querySelector<HTMLElement>('.lights-gantry');
    const wordmark = loader.querySelector<HTMLElement>('.loader-wordmark');
    const underline = loader.querySelector<HTMLElement>('.loader-underline');
    const tagline = loader.querySelector<HTMLElement>('.loader-tagline');

    pods.forEach((pod, i) => {
      setTimeout(() => pod.classList.add('lit'), 350 + i * 180);
    });

    setTimeout(() => {
      gantry?.classList.add('lights-out');
      wordmark?.classList.add('slam');
      setTimeout(() => underline?.classList.add('draw'), 220);
      setTimeout(() => tagline?.classList.add('fade'), 420);
    }, 1370);

    setTimeout(() => {
      loader.classList.add('loader-exit');
      setTimeout(() => loader.remove(), 800);
    }, 2500);
  }
</script>
