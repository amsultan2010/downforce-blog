---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const { title, date, excerpt, tags, race, thumbnail } = post.data;

const dateStr = date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});
---

<article class:list={['post-card', { featured }]}>
  <a href={`/posts/${post.id}`} class="card-link" tabindex="-1" aria-hidden="true"></a>
  <div class="shimmer-layer" aria-hidden="true"></div>

  {thumbnail && (
    <div class="card-thumb">
      <img src={thumbnail} alt={title} loading="lazy" width="800" height="450"
        onerror="this.closest('.card-thumb').style.display='none'" />
    </div>
  )}

  <div class="card-meta">
    <time datetime={date.toISOString()} class="card-date">{dateStr}</time>
    {race && <span class="card-race">{race}</span>}
  </div>

  <h2 class="card-title">
    <a href={`/posts/${post.id}`}>{title}</a>
  </h2>

  <p class="card-excerpt">{excerpt}</p>

  <div class="card-footer">
    <ul class="card-tags" aria-label="Tags">
      {tags.map((tag: string) => (
        <li class="card-tag">{tag}</li>
      ))}
    </ul>
    <span class="card-arrow" aria-hidden="true">→</span>
  </div>
</article>

<style>
  .post-card {
    position: relative;
    background: var(--bg-card);
    padding: 1.75rem 2rem;
    border: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    overflow: hidden;
    transition: box-shadow 0.25s var(--ease-out-quint), transform 0.25s var(--ease-out-quint);
  }

  /* gradient bottom border sweep */
  .post-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--amber), var(--blue));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s var(--ease-out-quint);
    pointer-events: none;
  }

  .post-card:hover::after {
    transform: scaleX(1);
  }

  /* shimmer sweep on top layer */
  .post-card .shimmer-layer {
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 40%, rgba(243,237,225,0.07) 50%, transparent 60%);
    transform: translateX(-100%) skewX(-12deg);
    pointer-events: none;
  }

  .post-card:hover .shimmer-layer {
    animation: shimmer 0.6s var(--ease-out-quint) forwards;
  }

  .post-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--accent);
    opacity: 0.2;
    transition: opacity 0.3s var(--ease-out-quint);
  }

  .post-card:hover {
    box-shadow: 0 8px 40px rgba(232, 74, 37, 0.1), 0 2px 12px rgba(27, 58, 38, 0.08);
    transform: translateY(-3px);
  }

  .post-card:hover::before {
    opacity: 1;
  }

  /* mobile: tap feedback instead of hover */
  @media (hover: none) {
    .post-card:active {
      transform: scale(0.985);
      box-shadow: 0 2px 12px rgba(232, 74, 37, 0.12);
    }
    .post-card:active::after {
      transform: scaleX(1);
    }
  }

  /* Thumbnail */
  .card-thumb {
    margin: -1.75rem -2rem 0;
    height: 200px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(0.9) saturate(0.9);
    transition: filter 0.35s ease, transform 0.35s ease;
  }

  .post-card:hover .card-thumb img {
    filter: brightness(1) saturate(1);
    transform: scale(1.03);
  }

  /* Featured card */
  .post-card.featured {
    padding: 2.25rem 2.5rem;
  }

  .post-card.featured .card-thumb {
    height: 280px;
    margin: -2.25rem -2.5rem 0;
  }

  .post-card.featured .card-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
  }

  .post-card.featured .card-excerpt {
    font-size: 1rem;
    max-width: 60ch;
  }

  /* Invisible overlay link for the entire card */
  .card-link {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .card-date {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .card-race {
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--accent);
    letter-spacing: 0.04em;
    text-transform: lowercase;
    font-style: italic;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.01em;
    position: relative;
    z-index: 1;
  }

  .card-title a {
    color: var(--text);
    transition: color 0.2s ease;
  }

  .post-card:hover .card-title a {
    color: var(--accent);
  }

  .card-excerpt {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--text-muted);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.25rem;
    position: relative;
    z-index: 1;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .card-tag {
    font-size: 0.8125rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-tint);
    border: 1px solid transparent;
    padding: 0.2em 0.6em;
    border-radius: var(--radius-sm);
  }

  .card-tag:nth-child(3n+2) {
    color: var(--blue);
    background: var(--blue-tint);
  }

  .card-tag:nth-child(3n+3) {
    color: var(--amber);
    background: var(--amber-tint);
  }

  .card-arrow {
    font-size: 1rem;
    color: var(--border-strong);
    transition: color 0.2s ease, transform 0.2s ease;
    display: inline-block;
  }

  .post-card:hover .card-arrow {
    color: var(--accent);
    transform: translateX(4px);
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.post-card').forEach(card => {
    card.style.transition = card.style.transition + ', transform 0.08s ease';
    card.addEventListener('mousemove', e => {
      const r = card.getBoundingClientRect();
      const rx = ((e.clientY - r.top  - r.height / 2) / r.height *  7).toFixed(2);
      const ry = ((e.clientX - r.left - r.width  / 2) / r.width  * -7).toFixed(2);
      card.style.transform = `perspective(900px) rotateX(${rx}deg) rotateY(${ry}deg) translateY(-3px)`;
    });
    card.addEventListener('mouseleave', () => { card.style.transform = ''; });
  });
</script>
