---
// All data fetched client-side from Jolpica API — shows all drivers/constructors
---

<section class="standings-section reveal-on-scroll" id="standings">
  <div class="container">
    <div class="standings-header">
      <div>
        <h2 class="standings-title">championship standings</h2>
        <span class="standings-round" id="standings-round">loading…</span>
      </div>
      <div class="live-badge">
        <span class="live-dot"></span>
        <span class="live-label">live</span>
      </div>
    </div>

    <div class="standings-grid">
      <div class="standings-panel">
        <div class="panel-header">
          <span class="panel-label">drivers</span>
          <span class="panel-rule"></span>
          <span class="panel-count" id="driver-count"></span>
        </div>
        <ol class="standings-list" id="drivers-list" aria-label="Driver standings">
          {Array.from({ length: 20 }).map((_, i) => (
            <li class="standings-row skeleton" style={`animation-delay:${i*0.04}s`}>
              <span class="sk-pos"></span>
              <span class="sk-mid">
                <span class="sk-name"></span>
                <span class="sk-sub"></span>
              </span>
              <span class="sk-pts"></span>
            </li>
          ))}
        </ol>
      </div>

      <div class="standings-panel">
        <div class="panel-header">
          <span class="panel-label">constructors</span>
          <span class="panel-rule"></span>
          <span class="panel-count" id="constructor-count"></span>
        </div>
        <ol class="standings-list" id="constructors-list" aria-label="Constructor standings">
          {Array.from({ length: 10 }).map((_, i) => (
            <li class="standings-row skeleton" style={`animation-delay:${i*0.05}s`}>
              <span class="sk-pos"></span>
              <span class="sk-mid">
                <span class="sk-name"></span>
                <span class="sk-sub"></span>
              </span>
              <span class="sk-pts"></span>
            </li>
          ))}
        </ol>
      </div>
    </div>

    <p class="standings-error" id="standings-error" hidden>
      standings unavailable — api offline
    </p>
  </div>
</section>

<style>
  .standings-section {
    background: var(--bg-dark);
    padding: 5rem 0 5.5rem;
    position: relative;
    overflow: hidden;
  }

  /* subtle diagonal texture */
  .standings-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      -45deg,
      rgba(243,237,225,0.015) 0px,
      rgba(243,237,225,0.015) 1px,
      transparent 1px,
      transparent 28px
    );
    pointer-events: none;
  }

  /* ── header ── */
  .standings-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 3rem;
    gap: 1.5rem;
    position: relative;
  }

  .standings-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--text-light);
    text-transform: lowercase;
    line-height: 1;
    margin-bottom: 0.45rem;
  }

  .standings-round {
    font-size: 1rem;
    color: var(--text-light-muted);
    font-style: italic;
    letter-spacing: 0.02em;
  }

  .live-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(61,220,132,0.1);
    border: 1px solid rgba(61,220,132,0.2);
    padding: 0.35rem 0.75rem;
    border-radius: 2rem;
    flex-shrink: 0;
    margin-top: 0.25rem;
  }

  .live-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #3ddc84;
    display: block;
    position: relative;
  }

  .live-dot::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: rgba(61,220,132,0.3);
    animation: livePulse 2s ease-out infinite;
  }

  @keyframes livePulse {
    0% { transform: scale(0.5); opacity: 1; }
    100% { transform: scale(2.2); opacity: 0; }
  }

  .live-label {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #3ddc84;
  }

  /* ── two-column grid ── */
  .standings-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3.5rem;
    position: relative;
  }

  @media (max-width: 860px) {
    .standings-grid { grid-template-columns: 1fr; gap: 3rem; }
  }

  /* ── panel header ── */
  .panel-header {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(243,237,225,0.12);
  }

  .panel-label {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-light-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .panel-rule {
    flex: 1;
    height: 1px;
    background: rgba(243,237,225,0.08);
  }

  .panel-count {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: rgba(243,237,225,0.25);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── rows ── */
  .standings-list { display: flex; flex-direction: column; }

  .standings-row {
    display: grid;
    grid-template-columns: 3rem 6px 1fr auto;
    align-items: center;
    gap: 0;
    padding: 0.6rem 0.5rem 0.6rem 0;
    border-bottom: 1px solid rgba(243,237,225,0.05);
    position: relative;
    cursor: default;
    transition: background 0.18s ease, padding-left 0.18s ease;
    border-radius: 2px;
  }

  .standings-row:hover {
    background: rgba(243,237,225,0.05);
    padding-left: 0.4rem;
  }

  /* ── position number — color set inline by JS ── */
  .s-pos {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 800;
    text-align: center;
    line-height: 1;
    /* color injected as inline style */
  }

  /* ── color swatch bar ── */
  .s-swatch {
    width: 3px;
    align-self: stretch;
    margin: 0.2rem 0.85rem 0.2rem 0.4rem;
    border-radius: 2px;
    flex-shrink: 0;
    /* background injected as inline style */
  }

  /* ── name block ── */
  .s-body {
    display: flex;
    flex-direction: column;
    gap: 0.12rem;
    min-width: 0;
    padding-right: 0.5rem;
  }

  .s-driver {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-light);
    letter-spacing: 0.01em;
    line-height: 1.1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .s-driver strong {
    font-weight: 800;
    letter-spacing: 0.02em;
  }

  .s-team {
    font-size: 0.78rem;
    color: var(--text-light-muted);
    font-weight: 300;
    letter-spacing: 0.06em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── points column ── */
  .s-pts-block {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
    min-width: 5rem;
  }

  .s-pts {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--text-light);
    line-height: 1;
    white-space: nowrap;
  }

  .pts-label {
    font-size: 0.65rem;
    font-weight: 400;
    color: var(--text-light-muted);
    letter-spacing: 0.08em;
    margin-left: 0.15rem;
    text-transform: uppercase;
  }

  .s-bar-track {
    width: 100%;
    height: 2px;
    background: rgba(243,237,225,0.07);
    border-radius: 1px;
    overflow: hidden;
  }

  .s-bar-fill {
    height: 100%;
    border-radius: 1px;
    transform-origin: left;
    transform: scaleX(0);
    transition: transform 0.9s var(--ease-out-quint);
  }

  /* gap-to-leader badge */
  .s-gap {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 600;
    color: rgba(243,237,225,0.3);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  /* leader badge */
  .s-gap.leader {
    color: var(--amber);
    letter-spacing: 0.06em;
  }

  /* ── wins pill ── */
  .s-wins {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: rgba(243,237,225,0.35);
  }

  .s-wins.has-wins { color: var(--amber); }

  /* ── skeleton ── */
  .skeleton {
    animation: skIn 0.4s ease both;
  }

  @keyframes skIn {
    from { opacity: 0; transform: translateX(-6px); }
    to { opacity: 1; transform: none; }
  }

  .sk-pos, .sk-name, .sk-sub, .sk-pts {
    display: block;
    background: rgba(243,237,225,0.07);
    border-radius: 3px;
    animation: shimmer 1.6s ease-in-out infinite;
  }

  .sk-pos   { width: 1.5rem; height: 1.5rem; margin: 0 auto; }
  .sk-mid   { display: flex; flex-direction: column; gap: 0.3rem; padding: 0 1rem; }
  .sk-name  { width: 9rem; height: 1rem; }
  .sk-sub   { width: 5.5rem; height: 0.7rem; }
  .sk-pts   { width: 3rem; height: 1.2rem; margin-left: auto; }

  @keyframes shimmer {
    0%, 100% { opacity: 0.25; }
    50% { opacity: 0.6; }
  }

  .standings-error {
    font-size: 1rem;
    color: var(--text-light-muted);
    font-style: italic;
    margin-top: 2rem;
    text-align: center;
  }
</style>

<script>
  const BASE = 'https://api.jolpi.ca/ergast/f1';

  const TEAM_COLORS: Record<string, string> = {
    'McLaren':        '#FF8000',
    'Red Bull':       '#1E41CB',
    'Ferrari':        '#E8002D',
    'Mercedes':       '#27F4D2',
    'Aston Martin':   '#229971',
    'Alpine':         '#FF87BC',
    'Williams':       '#64C4FF',
    'RB':             '#6692FF',
    'Visa Cash App':  '#6692FF',
    'Kick Sauber':    '#52E252',
    'Sauber':         '#52E252',
    'Haas':           '#FFFFFF',
    'Haas F1 Team':   '#FFFFFF',
    'Audi':           '#C0C0C0',
    'Cadillac':       '#333333',
  };

  function teamColor(name: string): string {
    for (const [key, color] of Object.entries(TEAM_COLORS)) {
      if (name.includes(key)) return color;
    }
    return 'rgba(243,237,225,0.35)';
  }

  function animateBars() {
    document.querySelectorAll<HTMLElement>('.s-bar-fill').forEach(el => {
      el.style.transform = `scaleX(${el.dataset.width ?? 0})`;
    });
  }

  function renderDrivers(standings: any[]) {
    const list = document.getElementById('drivers-list');
    const countEl = document.getElementById('driver-count');
    if (!list) return;
    if (countEl) countEl.textContent = `${standings.length} drivers`;

    const maxPts = parseFloat(standings[0]?.points ?? 1);

    list.innerHTML = standings.map((d: any, idx: number) => {
      const color = teamColor(d.Constructors[0]?.name ?? '');
      const pts = parseFloat(d.points);
      const pct = (pts / maxPts).toFixed(3);
      const gap = idx === 0 ? 'leader' : `-${(maxPts - pts).toFixed(0)}`;
      const lastName = d.Driver.familyName.toUpperCase();
      const firstName = d.Driver.givenName;
      return `
        <li class="standings-row" data-pos="${d.position}">
          <span class="s-pos" style="color:${color}">${d.position}</span>
          <span class="s-swatch" style="background:${color}" aria-hidden="true"></span>
          <span class="s-body">
            <span class="s-driver">${firstName} <strong>${lastName}</strong></span>
            <span class="s-team">${d.Constructors[0]?.name ?? ''}</span>
          </span>
          <span class="s-pts-block">
            <span class="s-pts">${d.points}<span class="pts-label">pts</span></span>
            <span class="s-bar-track">
              <span class="s-bar-fill" data-width="${pct}" style="background:${color}"></span>
            </span>
            <span class="s-gap ${idx === 0 ? 'leader' : ''}">${idx === 0 ? '◆ leader' : gap + ' pts'}</span>
          </span>
        </li>`;
    }).join('');
    requestAnimationFrame(() => requestAnimationFrame(animateBars));
  }

  function renderConstructors(standings: any[]) {
    const list = document.getElementById('constructors-list');
    const countEl = document.getElementById('constructor-count');
    if (!list) return;
    if (countEl) countEl.textContent = `${standings.length} teams`;

    const maxPts = parseFloat(standings[0]?.points ?? 1);

    list.innerHTML = standings.map((c: any, idx: number) => {
      const color = teamColor(c.Constructor.name);
      const pts = parseFloat(c.points);
      const pct = (pts / maxPts).toFixed(3);
      const gap = idx === 0 ? 'leader' : `-${(maxPts - pts).toFixed(0)}`;
      return `
        <li class="standings-row" data-pos="${c.position}">
          <span class="s-pos" style="color:${color}">${c.position}</span>
          <span class="s-swatch" style="background:${color}" aria-hidden="true"></span>
          <span class="s-body">
            <span class="s-driver"><strong>${c.Constructor.name.toUpperCase()}</strong></span>
            <span class="s-team">${c.Constructor.nationality}</span>
          </span>
          <span class="s-pts-block">
            <span class="s-pts">${c.points}<span class="pts-label">pts</span></span>
            <span class="s-bar-track">
              <span class="s-bar-fill" data-width="${pct}" style="background:${color}"></span>
            </span>
            <span class="s-gap ${idx === 0 ? 'leader' : ''}">${idx === 0 ? '◆ leader' : gap + ' pts'}</span>
          </span>
        </li>`;
    }).join('');
    requestAnimationFrame(() => requestAnimationFrame(animateBars));
  }

  async function loadStandings() {
    try {
      const [dRes, cRes] = await Promise.all([
        fetch(`${BASE}/current/driverStandings/`),
        fetch(`${BASE}/current/constructorStandings/`),
      ]);
      if (!dRes.ok || !cRes.ok) throw new Error('api error');

      const [dData, cData] = await Promise.all([dRes.json(), cRes.json()]);

      const dList = dData.MRData?.StandingsTable?.StandingsLists?.[0];
      const cList = cData.MRData?.StandingsTable?.StandingsLists?.[0];

      if (dList) {
        const roundEl = document.getElementById('standings-round');
        if (roundEl) roundEl.textContent = `${dList.season} season · after round ${dList.round}`;
        renderDrivers(dList.DriverStandings);
      }
      if (cList) {
        renderConstructors(cList.ConstructorStandings);
      }
    } catch {
      const errEl = document.getElementById('standings-error');
      if (errEl) errEl.hidden = false;
      document.getElementById('drivers-list')?.remove();
      document.getElementById('constructors-list')?.remove();
    }
  }

  loadStandings();
</script>
