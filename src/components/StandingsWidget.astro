---
---

<section class="sw" id="standings">

  <div class="sw-head">
    <div class="sw-head-left">
      <span class="sw-eyebrow">2025 formula one</span>
      <h2 class="sw-title">championship</h2>
    </div>
    <div class="sw-head-right">
      <span class="sw-season" id="sw-season">—</span>
      <span class="sw-live-badge">
        <span class="sw-dot"></span>live data
      </span>
    </div>
  </div>

  <div class="sw-tabs" role="tablist">
    <button class="sw-tab active" data-tab="drivers" role="tab">drivers</button>
    <button class="sw-tab" data-tab="constructors" role="tab">constructors</button>
  </div>

  <div class="sw-panel" id="panel-drivers">
    <ul class="sw-list" id="drivers-list" aria-label="Driver standings">
      {Array.from({ length: 10 }).map((_, i) => (
        <li class="sw-row sw-skeleton" style={`--i:${i}`}>
          <span class="sk sk-pos"></span>
          <span class="sk sk-name"></span>
          <span class="sk sk-pts"></span>
        </li>
      ))}
    </ul>
    <button class="sw-more" id="expand-drivers" hidden>
      show all <span id="expand-count"></span> drivers ↓
    </button>
  </div>

  <div class="sw-panel sw-hidden" id="panel-constructors">
    <ul class="sw-list" id="constructors-list" aria-label="Constructor standings">
      {Array.from({ length: 10 }).map((_, i) => (
        <li class="sw-row sw-skeleton" style={`--i:${i}`}>
          <span class="sk sk-pos"></span>
          <span class="sk sk-name"></span>
          <span class="sk sk-pts"></span>
        </li>
      ))}
    </ul>
  </div>

  <p class="sw-err" id="sw-error" hidden>standings unavailable — check back soon</p>

</section>

<style>
  /* ── shell ── */
  .sw {
    background: #080f09;
    padding: 5rem 0 3rem;
    position: relative;
    overflow: hidden;
  }

  /* grid lines */
  .sw::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 80px 80px;
    pointer-events: none;
  }

  /* orange ambient glow */
  .sw::after {
    content: '';
    position: absolute;
    bottom: -120px; left: -120px;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(194,84,40,0.15) 0%, transparent 65%);
    pointer-events: none;
  }

  .sw > * { position: relative; z-index: 1; }

  /* ── header ── */
  .sw-head {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem 2rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .sw-eyebrow {
    display: block;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #C25428;
    margin-bottom: 0.3rem;
  }

  .sw-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: #F3EDE1;
    line-height: 0.9;
    text-transform: uppercase;
  }

  .sw-head-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.6rem;
    padding-bottom: 0.4rem;
  }

  .sw-season {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-style: italic;
    color: rgba(243,237,225,0.4);
    letter-spacing: 0.04em;
  }

  .sw-live-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #3ddc84;
    border: 1px solid rgba(61,220,132,0.25);
    background: rgba(61,220,132,0.07);
    padding: 0.3rem 0.7rem;
    border-radius: 100px;
  }

  .sw-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: #3ddc84;
    position: relative;
  }
  .sw-dot::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: rgba(61,220,132,0.3);
    animation: dotPulse 2s ease-out infinite;
  }
  @keyframes dotPulse {
    0% { transform: scale(0.5); opacity: 1; }
    100% { transform: scale(2.8); opacity: 0; }
  }

  /* ── tabs ── */
  .sw-tabs {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    gap: 0;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    margin-top: 2.5rem;
  }

  .sw-tab {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(243,237,225,0.3);
    padding: 0.8rem 1.75rem;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }
  .sw-tab:hover { color: rgba(243,237,225,0.65); }
  .sw-tab.active {
    color: #F3EDE1;
    border-bottom-color: #C25428;
  }

  /* ── panel ── */
  .sw-panel {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .sw-hidden { display: none; }

  /* ── list ── */
  .sw-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  /* ── row ── */
  .sw-row {
    display: grid;
    grid-template-columns: 5.5rem 6px 1fr auto;
    align-items: center;
    gap: 0;
    min-height: 88px;
    padding: 1.1rem 0 1.1rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    position: relative;
    overflow: hidden;
    opacity: 0;
    transform: translateX(-20px);
  }

  .sw-row:first-child { border-top: 1px solid rgba(255,255,255,0.05); }

  .sw-row.live {
    animation: rowSlide 0.45s cubic-bezier(0.22,1,0.36,1) calc(var(--i,0) * 50ms) both;
  }

  @keyframes rowSlide {
    from { opacity: 0; transform: translateX(-20px); }
    to   { opacity: 1; transform: none; }
  }

  /* fill sweep */
  .sw-row::after {
    content: '';
    position: absolute;
    inset: 0;
    width: var(--fill, 0%);
    background: var(--tc, transparent);
    opacity: 0.045;
    pointer-events: none;
    transition: opacity 0.2s;
  }
  .sw-row:hover::after { opacity: 0.09; }

  /* P1 gold shimmer */
  .sw-row[data-p="1"] {
    background: linear-gradient(90deg, rgba(212,149,42,0.07), transparent 55%);
  }

  /* podium left accent */
  .sw-row[data-p="1"] .sw-swatch,
  .sw-row[data-p="2"] .sw-swatch,
  .sw-row[data-p="3"] .sw-swatch {
    opacity: 1;
  }

  /* ── position ── */
  .sw-pos {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 800;
    text-align: center;
    line-height: 1;
    letter-spacing: -0.04em;
    position: relative;
    z-index: 1;
  }

  /* ── swatch ── */
  .sw-swatch {
    width: 4px;
    align-self: stretch;
    margin: 0.4rem 1.1rem 0.4rem 0.5rem;
    border-radius: 2px;
    position: relative;
    z-index: 1;
    opacity: 0.7;
  }

  /* ── body ── */
  .sw-body {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.2rem;
    min-width: 0;
    padding-right: 1.25rem;
    position: relative;
    z-index: 1;
  }

  .sw-name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: #F3EDE1;
    letter-spacing: 0.01em;
    line-height: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .sw-name strong {
    font-weight: 800;
    letter-spacing: 0.04em;
  }

  .sw-sub {
    font-size: 0.75rem;
    color: rgba(243,237,225,0.4);
    font-weight: 300;
    letter-spacing: 0.07em;
    white-space: nowrap;
  }

  /* gap bar */
  .sw-gap-bar {
    margin-top: 0.45rem;
    height: 3px;
    background: rgba(255,255,255,0.07);
    border-radius: 2px;
    overflow: hidden;
    max-width: 200px;
  }
  .sw-gap-fill {
    height: 100%;
    border-radius: 2px;
    transform-origin: left;
    transform: scaleX(0);
    transition: transform 1.1s cubic-bezier(0.22,1,0.36,1);
  }

  /* ── pts block ── */
  .sw-pts-block {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.2rem;
    min-width: 7rem;
    position: relative;
    z-index: 1;
    padding-right: 0.25rem;
  }

  .sw-pts {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 800;
    color: #F3EDE1;
    line-height: 1;
    letter-spacing: -0.02em;
    white-space: nowrap;
  }
  .sw-pts-unit {
    font-size: 0.65rem;
    font-weight: 400;
    color: rgba(243,237,225,0.35);
    letter-spacing: 0.12em;
    margin-left: 0.15rem;
    text-transform: uppercase;
  }

  .sw-delta {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: rgba(243,237,225,0.28);
    white-space: nowrap;
  }
  .sw-delta.leader { color: #D4952A; }

  /* ── expand btn ── */
  .sw-more {
    display: block;
    width: 100%;
    margin: 1.25rem 0 0.5rem;
    padding: 1rem;
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(243,237,225,0.4);
    border: 1px solid rgba(255,255,255,0.07);
    background: rgba(255,255,255,0.02);
    cursor: pointer;
    border-radius: 2px;
    transition: color 0.2s, background 0.2s, border-color 0.2s;
  }
  .sw-more:hover {
    color: #F3EDE1;
    background: rgba(255,255,255,0.05);
    border-color: rgba(255,255,255,0.14);
  }

  /* ── skeleton ── */
  .sw-skeleton {
    opacity: 1 !important;
    transform: none !important;
  }
  .sk {
    display: block;
    background: rgba(255,255,255,0.05);
    border-radius: 3px;
    animation: skShimmer 1.6s ease-in-out infinite;
    animation-delay: calc(var(--i,0) * 80ms);
  }
  @keyframes skShimmer {
    0%, 100% { opacity: 0.2; }
    50%       { opacity: 0.5; }
  }
  .sk-pos  { width: 2.5rem; height: 2.5rem; margin: 0 auto; border-radius: 50%; }
  .sk-name { width: 11rem; height: 1.25rem; }
  .sk-pts  { width: 4rem; height: 1.75rem; margin-left: auto; }

  /* ── error ── */
  .sw-err {
    max-width: 1100px;
    margin: 2rem auto;
    padding: 0 1.5rem;
    color: rgba(243,237,225,0.35);
    font-size: 1rem;
    font-style: italic;
    text-align: center;
  }

  /* ── responsive ── */
  @media (max-width: 600px) {
    .sw-row { grid-template-columns: 4rem 5px 1fr auto; min-height: 72px; }
    .sw-pos  { font-size: 2.25rem; }
    .sw-name { font-size: 1.2rem; }
    .sw-pts  { font-size: 1.75rem; }
    .sw-pts-block { min-width: 5.5rem; }
    .sw-gap-bar { max-width: 120px; }
  }
</style>

<script>
  const BASE = 'https://api.jolpi.ca/ergast/f1';
  const TOP = 10;

  const COLORS: Record<string,string> = {
    'McLaren':      '#FF8000',
    'Red Bull':     '#1E41CB',
    'Ferrari':      '#E8002D',
    'Mercedes':     '#27F4D2',
    'Aston Martin': '#229971',
    'Alpine':       '#FF87BC',
    'Williams':     '#64C4FF',
    'RB':           '#6692FF',
    'Visa Cash App':'#6692FF',
    'Kick Sauber':  '#52E252',
    'Sauber':       '#52E252',
    'Haas':         '#E8E8E8',
    'Audi':         '#C0C0C0',
    'Cadillac':     '#888888',
  };

  function color(name: string) {
    for (const [k,v] of Object.entries(COLORS)) {
      if (name.includes(k)) return v;
    }
    return '#888888';
  }

  function driverRow(d: any, i: number, maxPts: number): string {
    const tc = color(d.Constructors?.[0]?.name ?? '');
    const pts = parseFloat(d.points);
    const ratio = maxPts > 0 ? pts / maxPts : 0;
    const fillPct = (ratio * 100).toFixed(1) + '%';
    const delta = i === 0 ? '◆ championship leader' : `−${(maxPts - pts).toFixed(0)} pts`;
    const last = d.Driver.familyName.toUpperCase();
    const first = d.Driver.givenName[0] + '.';
    const team = d.Constructors?.[0]?.name ?? '';
    return `<li class="sw-row" data-p="${d.position}" style="--tc:${tc};--fill:${fillPct};--i:${i}">
      <span class="sw-pos" style="color:${tc}">${d.position}</span>
      <span class="sw-swatch" style="background:${tc}"></span>
      <span class="sw-body">
        <span class="sw-name">${first} <strong>${last}</strong></span>
        <span class="sw-sub">${team}</span>
        <span class="sw-gap-bar"><span class="sw-gap-fill" data-r="${ratio.toFixed(4)}" style="background:${tc}"></span></span>
      </span>
      <span class="sw-pts-block">
        <span class="sw-pts">${d.points}<span class="sw-pts-unit">pts</span></span>
        <span class="sw-delta ${i===0?'leader':''}">${delta}</span>
      </span>
    </li>`;
  }

  function constructorRow(c: any, i: number, maxPts: number): string {
    const tc = color(c.Constructor.name);
    const pts = parseFloat(c.points);
    const ratio = maxPts > 0 ? pts / maxPts : 0;
    const fillPct = (ratio * 100).toFixed(1) + '%';
    const delta = i === 0 ? '◆ championship leader' : `−${(maxPts - pts).toFixed(0)} pts`;
    return `<li class="sw-row" data-p="${c.position}" style="--tc:${tc};--fill:${fillPct};--i:${i}">
      <span class="sw-pos" style="color:${tc}">${c.position}</span>
      <span class="sw-swatch" style="background:${tc}"></span>
      <span class="sw-body">
        <span class="sw-name"><strong>${c.Constructor.name.toUpperCase()}</strong></span>
        <span class="sw-sub">${c.Constructor.nationality}</span>
        <span class="sw-gap-bar"><span class="sw-gap-fill" data-r="${ratio.toFixed(4)}" style="background:${tc}"></span></span>
      </span>
      <span class="sw-pts-block">
        <span class="sw-pts">${c.points}<span class="sw-pts-unit">pts</span></span>
        <span class="sw-delta ${i===0?'leader':''}">${delta}</span>
      </span>
    </li>`;
  }

  function animate(list: HTMLElement) {
    requestAnimationFrame(() => requestAnimationFrame(() => {
      list.querySelectorAll<HTMLElement>('.sw-row').forEach(r => r.classList.add('live'));
      list.querySelectorAll<HTMLElement>('.sw-gap-fill').forEach(el => {
        el.style.transform = `scaleX(${el.dataset.r ?? 0})`;
      });
    }));
  }

  let allDrivers: any[] = [];

  function showDrivers(drivers: any[], all = false) {
    const list = document.getElementById('drivers-list') as HTMLElement;
    const btn  = document.getElementById('expand-drivers') as HTMLButtonElement;
    const cnt  = document.getElementById('expand-count');
    if (!list) return;
    const shown = all ? drivers : drivers.slice(0, TOP);
    const max   = parseFloat(drivers[0]?.points ?? 1);
    list.innerHTML = shown.map((d,i) => driverRow(d,i,max)).join('');
    if (!all && drivers.length > TOP) {
      btn.hidden = false;
      if (cnt) cnt.textContent = String(drivers.length);
    } else {
      btn.hidden = true;
    }
    animate(list);
  }

  function showConstructors(ctors: any[]) {
    const list = document.getElementById('constructors-list') as HTMLElement;
    if (!list) return;
    const max = parseFloat(ctors[0]?.points ?? 1);
    list.innerHTML = ctors.map((c,i) => constructorRow(c,i,max)).join('');
    animate(list);
  }

  // tabs
  document.querySelectorAll<HTMLButtonElement>('.sw-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.sw-tab').forEach(t => t.classList.remove('active'));
      btn.classList.add('active');
      document.querySelectorAll('.sw-panel').forEach(p => p.classList.add('sw-hidden'));
      document.getElementById(`panel-${btn.dataset.tab}`)?.classList.remove('sw-hidden');
    });
  });

  // expand
  document.getElementById('expand-drivers')?.addEventListener('click', () => {
    showDrivers(allDrivers, true);
  });

  async function load() {
    try {
      const [dr, cr] = await Promise.all([
        fetch(`${BASE}/current/driverStandings/`),
        fetch(`${BASE}/current/constructorStandings/`),
      ]);
      if (!dr.ok || !cr.ok) throw new Error('api error');
      const [dd, cd] = await Promise.all([dr.json(), cr.json()]);
      const dList = dd.MRData?.StandingsTable?.StandingsLists?.[0];
      const cList = cd.MRData?.StandingsTable?.StandingsLists?.[0];
      if (dList) {
        const el = document.getElementById('sw-season');
        if (el) el.textContent = `${dList.season} · round ${dList.round}`;
        allDrivers = dList.DriverStandings;
        showDrivers(allDrivers);
      }
      if (cList) showConstructors(cList.ConstructorStandings);
    } catch {
      const err = document.getElementById('sw-error');
      if (err) err.hidden = false;
    }
  }

  load();
</script>
