---
---

<section id="standings">

  <div class="sw-head">
    <div class="sw-head-left">
      <span class="sw-eyebrow">2025 formula one</span>
      <h2 class="sw-title">championship</h2>
    </div>
    <div class="sw-head-right">
      <span class="sw-season" id="sw-season">—</span>
      <span class="sw-live-badge">
        <span class="sw-dot"></span>live data
      </span>
    </div>
  </div>

  <div class="sw-tabs" role="tablist">
    <button class="sw-tab sw-tab-active" data-tab="drivers" role="tab">drivers</button>
    <button class="sw-tab" data-tab="constructors" role="tab">constructors</button>
  </div>

  <div class="sw-panel" id="panel-drivers">
    <ul class="sw-list" id="drivers-list" aria-label="Driver standings">
      {Array.from({ length: 10 }).map((_, i) => (
        <li class="sw-row sw-skeleton" style={`--i:${i}`}>
          <span class="sk sk-pos"></span>
          <span class="sk sk-name"></span>
          <span class="sk sk-pts"></span>
        </li>
      ))}
    </ul>
    <button class="sw-more" id="expand-drivers" hidden>
      show all <span id="expand-count"></span> drivers ↓
    </button>
  </div>

  <div class="sw-panel sw-panel-hidden" id="panel-constructors">
    <ul class="sw-list" id="constructors-list" aria-label="Constructor standings">
      {Array.from({ length: 10 }).map((_, i) => (
        <li class="sw-row sw-skeleton" style={`--i:${i}`}>
          <span class="sk sk-pos"></span>
          <span class="sk sk-name"></span>
          <span class="sk sk-pts"></span>
        </li>
      ))}
    </ul>
  </div>

  <p class="sw-err" id="sw-error" hidden>standings unavailable — check back soon</p>

</section>

<!-- is:global so CSS applies to innerHTML-injected rows too -->
<style is:global>
  /* ── shell ── */
  #standings {
    background: #080f09;
    padding: 5rem 0 3rem;
    position: relative;
    overflow: hidden;
    font-size: 16px; /* reset so rem values inside widget use 16px */
  }

  #standings::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.07) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.07) 1px, transparent 1px);
    background-size: 80px 80px;
    pointer-events: none;
  }

  #standings::after {
    content: '';
    position: absolute;
    bottom: -120px; left: -120px;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(194,84,40,0.14) 0%, transparent 65%);
    pointer-events: none;
  }

  #standings > * { position: relative; z-index: 1; }

  /* ── header ── */
  #standings .sw-head {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem 2rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  #standings .sw-eyebrow {
    display: block;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #C25428;
    margin-bottom: 0.3rem;
  }

  #standings .sw-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: #F3EDE1;
    line-height: 0.9;
    text-transform: uppercase;
  }

  #standings .sw-head-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.6rem;
    padding-bottom: 0.4rem;
  }

  #standings .sw-season {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.875rem;
    font-style: italic;
    color: rgba(243,237,225,0.4);
    letter-spacing: 0.04em;
  }

  #standings .sw-live-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #3ddc84;
    border: 1px solid rgba(61,220,132,0.25);
    background: rgba(61,220,132,0.07);
    padding: 0.3rem 0.7rem;
    border-radius: 100px;
  }

  #standings .sw-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: #3ddc84;
    position: relative;
    flex-shrink: 0;
  }
  #standings .sw-dot::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: rgba(61,220,132,0.3);
    animation: swDotPulse 2s ease-out infinite;
  }
  @keyframes swDotPulse {
    0%   { transform: scale(0.5); opacity: 1; }
    100% { transform: scale(2.8); opacity: 0; }
  }

  /* ── tabs ── */
  #standings .sw-tabs {
    max-width: 1100px;
    margin: 2.5rem auto 0;
    padding: 0 1.5rem;
    display: flex;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  #standings .sw-tab {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(243,237,225,0.3);
    padding: 0.8rem 1.75rem;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    cursor: pointer;
    background: none;
    border-left: none;
    border-right: none;
    border-top: none;
    transition: color 0.2s, border-color 0.2s;
  }
  #standings .sw-tab:hover { color: rgba(243,237,225,0.65); }
  #standings .sw-tab.sw-tab-active {
    color: #F3EDE1;
    border-bottom-color: #C25428;
  }

  /* ── panel ── */
  #standings .sw-panel {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  #standings .sw-panel-hidden { display: none; }

  /* ── list ── */
  #standings .sw-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  /* ── row ── */
  #standings .sw-row {
    display: grid;
    grid-template-columns: 64px 5px 1fr auto;
    align-items: center;
    gap: 0;
    min-height: 80px;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    position: relative;
    overflow: hidden;
    opacity: 0;
    transform: translateX(-16px);
    cursor: default;
  }
  #standings .sw-row:first-child { border-top: 1px solid rgba(255,255,255,0.05); }

  /* row enter */
  #standings .sw-row.sw-live {
    animation: swRowIn 0.45s cubic-bezier(0.22,1,0.36,1) calc(var(--i,0) * 50ms) both;
  }
  @keyframes swRowIn {
    from { opacity: 0; transform: translateX(-16px); }
    to   { opacity: 1; transform: none; }
  }

  /* background fill sweep */
  #standings .sw-row::after {
    content: '';
    position: absolute;
    inset: 0;
    width: var(--fill, 0%);
    background: var(--tc, transparent);
    opacity: 0.04;
    pointer-events: none;
    transition: opacity 0.2s;
  }
  #standings .sw-row:hover::after { opacity: 0.09; }

  /* P1 gold tint */
  #standings .sw-row[data-p="1"] {
    background: linear-gradient(90deg, rgba(212,149,42,0.07), transparent 50%);
  }

  /* ── skeleton override ── */
  #standings .sw-skeleton {
    opacity: 1 !important;
    transform: none !important;
    animation: none !important;
    grid-template-columns: 64px 5px 1fr auto;
  }
  #standings .sk {
    display: block;
    background: rgba(255,255,255,0.06);
    border-radius: 3px;
    animation: swShimmer 1.6s ease-in-out calc(var(--i,0) * 80ms) infinite;
  }
  @keyframes swShimmer {
    0%, 100% { opacity: 0.18; }
    50%       { opacity: 0.45; }
  }
  #standings .sk-pos  { width: 36px; height: 36px; margin: 0 auto; border-radius: 50%; }
  #standings .sk-name { width: 140px; height: 18px; }
  #standings .sk-pts  { width: 52px;  height: 26px; margin-left: auto; }

  /* ── position number ── */
  #standings .sw-pos {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 2.5rem;
    font-weight: 800;
    text-align: center;
    line-height: 1;
    letter-spacing: -0.03em;
    position: relative;
    z-index: 1;
  }

  /* ── team swatch ── */
  #standings .sw-swatch {
    width: 4px;
    align-self: stretch;
    margin: 0.35rem 14px 0.35rem 6px;
    border-radius: 2px;
    opacity: 0.75;
    position: relative;
    z-index: 1;
    flex-shrink: 0;
  }

  /* ── body ── */
  #standings .sw-body {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.18rem;
    min-width: 0;
    padding-right: 1rem;
    position: relative;
    z-index: 1;
  }

  #standings .sw-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.35rem;
    font-weight: 700;
    color: #F3EDE1;
    letter-spacing: 0.01em;
    line-height: 1.05;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  #standings .sw-name strong {
    font-weight: 800;
    letter-spacing: 0.04em;
  }

  #standings .sw-sub {
    font-family: 'Jost', sans-serif;
    font-size: 0.72rem;
    color: rgba(243,237,225,0.38);
    font-weight: 300;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  #standings .sw-gap-bar {
    margin-top: 0.4rem;
    height: 3px;
    background: rgba(255,255,255,0.07);
    border-radius: 2px;
    overflow: hidden;
    max-width: 180px;
  }
  #standings .sw-gap-fill {
    height: 100%;
    border-radius: 2px;
    transform-origin: left;
    transform: scaleX(0);
    transition: transform 1.1s cubic-bezier(0.22,1,0.36,1);
  }

  /* ── points block ── */
  #standings .sw-pts-block {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.2rem;
    min-width: 90px;
    position: relative;
    z-index: 1;
    padding-right: 4px;
  }

  #standings .sw-pts {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 2rem;
    font-weight: 800;
    color: #F3EDE1;
    line-height: 1;
    letter-spacing: -0.02em;
    white-space: nowrap;
  }
  #standings .sw-pts-unit {
    font-size: 0.6rem;
    font-weight: 400;
    color: rgba(243,237,225,0.32);
    letter-spacing: 0.12em;
    margin-left: 2px;
    text-transform: uppercase;
  }

  #standings .sw-delta {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: rgba(243,237,225,0.25);
    white-space: nowrap;
  }
  #standings .sw-delta.sw-leader { color: #D4952A; }

  /* ── expand button ── */
  #standings .sw-more {
    display: block;
    width: 100%;
    margin: 1.25rem 0 0.5rem;
    padding: 0.9rem;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(243,237,225,0.38);
    border: 1px solid rgba(255,255,255,0.07);
    background: rgba(255,255,255,0.02);
    cursor: pointer;
    border-radius: 2px;
    transition: color 0.2s, background 0.2s, border-color 0.2s;
  }
  #standings .sw-more:hover {
    color: #F3EDE1;
    background: rgba(255,255,255,0.05);
    border-color: rgba(255,255,255,0.14);
  }

  /* ── error ── */
  #standings .sw-err {
    max-width: 1100px;
    margin: 2rem auto;
    padding: 0 1.5rem;
    color: rgba(243,237,225,0.35);
    font-size: 1rem;
    font-style: italic;
    text-align: center;
  }

  /* ── Fernando Alonso — The Chairman ── */
  #standings .sw-row.sw-alonso {
    background: linear-gradient(90deg,
      rgba(212,149,42,0.22) 0%,
      rgba(212,149,42,0.10) 45%,
      rgba(212,149,42,0.03) 70%,
      transparent 100%
    );
    border-top: 1px solid rgba(212,149,42,0.35) !important;
    border-bottom: 1px solid rgba(212,149,42,0.35);
    min-height: 104px;
    overflow: hidden;
  }

  /* gold shimmer sweep */
  #standings .sw-row.sw-alonso::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg,
      transparent 30%,
      rgba(212,149,42,0.18) 50%,
      transparent 70%
    );
    transform: translateX(-100%) skewX(-8deg);
    animation: alonsoShimmer 4s ease-in-out 1s infinite;
    pointer-events: none;
    z-index: 0;
  }

  @keyframes alonsoShimmer {
    0%   { transform: translateX(-120%) skewX(-8deg); opacity: 0; }
    15%  { opacity: 1; }
    85%  { opacity: 1; }
    100% { transform: translateX(180%) skewX(-8deg); opacity: 0; }
  }

  /* gold outline glow on sides */
  #standings .sw-row.sw-alonso::after {
    background: rgba(212,149,42,0.08) !important;
    opacity: 1 !important;
    width: 100% !important;
    box-shadow: inset 0 0 0 1px rgba(212,149,42,0.2);
  }

  #standings .sw-row.sw-alonso .sw-pos {
    font-size: 3.2rem;
    text-shadow: 0 0 24px rgba(212,149,42,0.6);
  }

  #standings .sw-row.sw-alonso .sw-name {
    font-size: 1.65rem;
    color: #F5D78E;
    text-shadow: 0 0 12px rgba(212,149,42,0.3);
  }

  #standings .sw-row.sw-alonso .sw-swatch {
    box-shadow: 0 0 10px rgba(212,149,42,0.7);
  }

  #standings .sw-row.sw-alonso .sw-pts {
    color: #F5D78E;
    font-size: 2.3rem;
    text-shadow: 0 0 14px rgba(212,149,42,0.4);
  }

  #standings .sw-alonso-badge {
    display: inline-block;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #D4952A;
    border: 1px solid rgba(212,149,42,0.5);
    background: rgba(212,149,42,0.12);
    padding: 0.15em 0.5em;
    border-radius: 2px;
    margin-left: 0.5rem;
    vertical-align: middle;
    position: relative;
    top: -1px;
    white-space: nowrap;
  }

  /* ── responsive ── */
  @media (max-width: 600px) {
    #standings .sw-row { grid-template-columns: 52px 4px 1fr auto; min-height: 68px; }
    #standings .sw-pos  { font-size: 1.9rem; }
    #standings .sw-name { font-size: 1.1rem; }
    #standings .sw-pts  { font-size: 1.6rem; }
    #standings .sw-pts-block { min-width: 72px; }
    #standings .sw-gap-bar { max-width: 110px; }
  }
</style>

<script>
  const BASE = 'https://api.jolpi.ca/ergast/f1';
  const TOP = 10;

  const COLORS: Record<string,string> = {
    'McLaren':       '#FF8000',
    'Red Bull':      '#1E41CB',
    'Ferrari':       '#E8002D',
    'Mercedes':      '#27F4D2',
    'Aston Martin':  '#229971',
    'Alpine':        '#FF87BC',
    'Williams':      '#64C4FF',
    'RB':            '#6692FF',
    'Visa Cash App': '#6692FF',
    'Kick Sauber':   '#52E252',
    'Sauber':        '#52E252',
    'Haas':          '#E8E8E8',
    'Audi':          '#8B0000',
    'Cadillac':      '#888888',
  };

  function color(name: string) {
    for (const [k, v] of Object.entries(COLORS)) {
      if (name.includes(k)) return v;
    }
    return '#888888';
  }

  function driverRow(d: any, animIdx: number, maxPts: number): string {
    const tc   = color(d.Constructors?.[0]?.name ?? '');
    const pts  = parseFloat(d.points);
    const ratio = maxPts > 0 ? pts / maxPts : 0;
    const fill  = (ratio * 100).toFixed(1) + '%';
    const isLeader = d.position === '1';
    const delta = isLeader ? '◆ leader' : `−${(maxPts - pts).toFixed(0)} pts`;
    const leaderCls = isLeader ? ' sw-leader' : '';
    const last  = d.Driver.familyName.toUpperCase();
    const first = d.Driver.givenName[0] + '.';
    const team  = d.Constructors?.[0]?.name ?? '';
    const isAlonso = d.Driver.familyName === 'Alonso';
    const alonsoClass = isAlonso ? ' sw-alonso' : '';
    const alonsoLabel = isAlonso ? `<span class="sw-alonso-badge">◆ G.O.A.T</span>` : '';
    const rowTc = isAlonso ? '#D4952A' : tc;
    return `<li class="sw-row${alonsoClass}" data-p="${d.position}" style="--tc:${rowTc};--fill:${fill};--i:${animIdx}">
      <span class="sw-pos" style="color:${rowTc}">${d.position}</span>
      <span class="sw-swatch" style="background:${rowTc}"></span>
      <span class="sw-body">
        <span class="sw-name">${first} <strong>${last}</strong>${alonsoLabel}</span>
        <span class="sw-sub">${team}</span>
        <span class="sw-gap-bar"><span class="sw-gap-fill" data-r="${ratio.toFixed(4)}" style="background:${rowTc}"></span></span>
      </span>
      <span class="sw-pts-block">
        <span class="sw-pts">${d.points}<span class="sw-pts-unit">pts</span></span>
        <span class="sw-delta${leaderCls}">${delta}</span>
      </span>
    </li>`;
  }

  function constructorRow(c: any, i: number, maxPts: number): string {
    const tc   = color(c.Constructor.name);
    const pts  = parseFloat(c.points);
    const ratio = maxPts > 0 ? pts / maxPts : 0;
    const fill  = (ratio * 100).toFixed(1) + '%';
    const delta = i === 0 ? '◆ leader' : `−${(maxPts - pts).toFixed(0)} pts`;
    const leaderCls = i === 0 ? ' sw-leader' : '';
    return `<li class="sw-row" data-p="${c.position}" style="--tc:${tc};--fill:${fill};--i:${i}">
      <span class="sw-pos" style="color:${tc}">${c.position}</span>
      <span class="sw-swatch" style="background:${tc}"></span>
      <span class="sw-body">
        <span class="sw-name"><strong>${c.Constructor.name.toUpperCase()}</strong></span>
        <span class="sw-sub">${c.Constructor.nationality}</span>
        <span class="sw-gap-bar"><span class="sw-gap-fill" data-r="${ratio.toFixed(4)}" style="background:${tc}"></span></span>
      </span>
      <span class="sw-pts-block">
        <span class="sw-pts">${c.points}<span class="sw-pts-unit">pts</span></span>
        <span class="sw-delta${leaderCls}">${delta}</span>
      </span>
    </li>`;
  }

  function animate(list: HTMLElement) {
    requestAnimationFrame(() => requestAnimationFrame(() => {
      list.querySelectorAll<HTMLElement>('.sw-row').forEach(r => r.classList.add('sw-live'));
      list.querySelectorAll<HTMLElement>('.sw-gap-fill').forEach(el => {
        el.style.transform = `scaleX(${el.dataset.r ?? 0})`;
      });
    }));
  }

  let allDrivers: any[] = [];

  function showDrivers(drivers: any[], all = false) {
    const list = document.getElementById('drivers-list') as HTMLElement | null;
    const btn  = document.getElementById('expand-drivers') as HTMLButtonElement | null;
    const cnt  = document.getElementById('expand-count') as HTMLElement | null;
    if (!list) return;
    let shown = all ? drivers : drivers.slice(0, TOP);
    if (!all) {
      const alonsoIdx = drivers.findIndex(d => d.Driver.familyName === 'Alonso');
      if (alonsoIdx >= TOP) shown = [...shown, drivers[alonsoIdx]];
    }
    const maxPts = parseFloat(drivers[0]?.points ?? '1');
    list.innerHTML = shown.map((d, i) => driverRow(d, i, maxPts)).join('');
    if (!all && drivers.length > TOP && btn) {
      btn.hidden = false;
      if (cnt) cnt.textContent = String(drivers.length);
    } else if (btn) {
      btn.hidden = true;
    }
    animate(list);
  }

  function showConstructors(ctors: any[]) {
    const list = document.getElementById('constructors-list') as HTMLElement | null;
    if (!list) return;
    const maxPts = parseFloat(ctors[0]?.points ?? '1');
    list.innerHTML = ctors.map((c, i) => constructorRow(c, i, maxPts)).join('');
    animate(list);
  }

  // tab switching
  document.querySelectorAll<HTMLButtonElement>('.sw-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.sw-tab').forEach(t => t.classList.remove('sw-tab-active'));
      btn.classList.add('sw-tab-active');
      document.querySelectorAll('.sw-panel').forEach(p => p.classList.add('sw-panel-hidden'));
      document.getElementById(`panel-${btn.dataset.tab}`)?.classList.remove('sw-panel-hidden');
    });
  });

  // expand
  document.getElementById('expand-drivers')?.addEventListener('click', () => {
    showDrivers(allDrivers, true);
  });

  // Returns the API path segment to use for standings.
  // Priority: if generate-post.js has published an article for the last race,
  // standings-state.json is updated and we show current standings immediately.
  // Otherwise fall back to time-based check: wait until race start + 2h + 5h
  // so late penalties don't make standings look wrong.
  async function resolveStandingsPath(): Promise<string> {
    const [schedRes, stateRes] = await Promise.all([
      fetch(`${BASE}/current/`),
      fetch('/standings-state.json').catch(() => null),
    ]);
    if (!schedRes.ok) return 'current';
    const sd = await schedRes.json();
    const races: any[] = sd.MRData?.RaceTable?.Races ?? [];
    const now = Date.now();
    const past = races.filter(r => {
      const start = new Date(`${r.date}T${r.time ?? '14:00:00Z'}`).getTime();
      return start <= now;
    });
    if (!past.length) return 'current';
    const last = past[past.length - 1];

    // If the race article has been published, standings are confirmed settled.
    if (stateRes?.ok) {
      const state = await stateRes.json().catch(() => null);
      if (state?.season === last.season && state?.unlockedRound === last.round) {
        return 'current';
      }
    }

    // Otherwise apply the time-based buffer.
    const raceStart = new Date(`${last.date}T${last.time ?? '14:00:00Z'}`).getTime();
    const RACE_DURATION_MS  = 2 * 60 * 60 * 1000;  // ~2h race
    const PENALTY_BUFFER_MS = 4 * 60 * 60 * 1000;  // 4h post-race buffer
    const settledAt = raceStart + RACE_DURATION_MS + PENALTY_BUFFER_MS;
    if (now < settledAt) {
      const prevRound = parseInt(last.round, 10) - 1;
      if (prevRound < 1) return 'current';
      return `${last.season}/${prevRound}`;
    }
    return 'current';
  }

  async function load() {
    try {
      const path = await resolveStandingsPath();
      const [dr, cr] = await Promise.all([
        fetch(`${BASE}/${path}/driverStandings/`),
        fetch(`${BASE}/${path}/constructorStandings/`),
      ]);
      if (!dr.ok || !cr.ok) throw new Error('api error');
      const [dd, cd] = await Promise.all([dr.json(), cr.json()]);
      const dList = dd.MRData?.StandingsTable?.StandingsLists?.[0];
      const cList = cd.MRData?.StandingsTable?.StandingsLists?.[0];
      if (dList) {
        const el = document.getElementById('sw-season');
        if (el) el.textContent = `${dList.season} · round ${dList.round}`;
        allDrivers = dList.DriverStandings;
        showDrivers(allDrivers);
      }
      if (cList) showConstructors(cList.ConstructorStandings);
    } catch {
      const err = document.getElementById('sw-error');
      if (err) err.hidden = false;
    }
  }

  load();
</script>
