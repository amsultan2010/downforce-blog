---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  excerpt: string;
  tags: string[];
  race?: string;
  thumbnail?: string;
}

const { title, date, excerpt, tags, race, thumbnail } = Astro.props;

const dateStr = date.toLocaleDateString('en-GB', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const schemaJson = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: excerpt,
  datePublished: date.toISOString(),
  author: {
    '@type': 'Organization',
    name: 'the downforce blog',
    url: Astro.site?.toString(),
  },
  publisher: {
    '@type': 'Organization',
    name: 'the downforce blog',
    url: Astro.site?.toString(),
  },
  ...(thumbnail ? { image: thumbnail } : {}),
});
---

<BaseLayout title={title} description={excerpt} ogImage={thumbnail} article>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schemaJson} />
  </Fragment>

  <div class="post-wrapper">
    <!-- Back link -->
    <div class="post-back container">
      <a href="/posts" class="back-link">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M8 2L3 7L8 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        all posts
      </a>
    </div>

    <!-- Post header -->
    <header class="post-header">
      <div class="container post-header-inner">
        <div class="post-meta-top">
          {race && <span class="post-race">{race}</span>}
          <time datetime={date.toISOString()} class="post-date">{dateStr}</time>
        </div>

        <h1 class="post-title">{title}</h1>

        <p class="post-excerpt">{excerpt}</p>

        <ul class="post-tags" aria-label="Tags">
          {tags.map(tag => (
            <li class="post-tag">{tag}</li>
          ))}
        </ul>
      </div>
    </header>

    <!-- Post body -->
    <div class="post-body container">
      <div class="prose">
        <slot />
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .post-wrapper {
    padding-top: 80px; /* header height */
  }

  .post-back {
    padding-top: 2rem;
    padding-bottom: 0;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8125rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    text-transform: lowercase;
    transition: color 0.2s ease;
  }

  .back-link:hover { color: var(--accent); }

  .post-header {
    padding: 2.5rem 0 3rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }

  .post-header-inner {
    max-width: var(--content-width);
  }

  .post-meta-top {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .post-race {
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--accent);
    text-transform: lowercase;
    letter-spacing: 0.04em;
    font-style: italic;
  }

  .post-date {
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 1.25rem;
  }

  .post-excerpt {
    font-size: 1.0625rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 1.5rem;
    max-width: 56ch;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .post-tag {
    font-size: 0.6875rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    border: 1px solid var(--border-strong);
    padding: 0.2em 0.6em;
  }

  .post-body {
    max-width: var(--content-width);
    padding-bottom: 6rem;
  }
</style>
