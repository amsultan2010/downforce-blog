---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  excerpt: string;
  tags: string[];
  race?: string;
  thumbnail?: string;
}

const { title, date, excerpt, tags, race, thumbnail } = Astro.props;

const dateStr = date.toLocaleDateString('en-GB', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const schemaJson = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: excerpt,
  datePublished: date.toISOString(),
  author: {
    '@type': 'Organization',
    name: 'the downforce blog',
    url: Astro.site?.toString(),
  },
  publisher: {
    '@type': 'Organization',
    name: 'the downforce blog',
    url: Astro.site?.toString(),
  },
  ...(thumbnail ? { image: thumbnail } : {}),
});
---

<BaseLayout title={title} description={excerpt} ogImage={thumbnail} article>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schemaJson} />
  </Fragment>

  <div class="post-wrapper">
    <!-- Back link -->
    <div class="post-back container">
      <a href="/posts" class="back-link">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M8 2L3 7L8 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        all posts
      </a>
    </div>

    <!-- Post header -->
    <header class="post-header">
      <div class="container post-header-inner">
        <div class="post-meta-top ph-anim" style="--d:0s">
          {race && <span class="post-race">{race}</span>}
          <time datetime={date.toISOString()} class="post-date">{dateStr}</time>
        </div>

        <h1 class="post-title ph-anim" style="--d:0.1s">{title}</h1>

        <p class="post-excerpt ph-anim" style="--d:0.2s">{excerpt}</p>

        <ul class="post-tags ph-anim" style="--d:0.28s" aria-label="Tags">
          {tags.map(tag => (
            <li class="post-tag">{tag}</li>
          ))}
        </ul>
      </div>
    </header>

    <!-- Post thumbnail -->
    {thumbnail && (
      <div class="post-thumb container">
        <img src={thumbnail} alt={title} width="1200" height="630" loading="eager"
          onerror="this.closest('.post-thumb').style.display='none'" />
      </div>
    )}

    <!-- Post body -->
    <div class="post-body container">
      <div class="prose">
        <slot />
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .post-wrapper {
    padding-top: 80px; /* header height */
  }

  .ph-anim {
    opacity: 0;
    transform: translateY(16px);
    filter: blur(3px);
    animation: phIn 0.6s cubic-bezier(0.22,1,0.36,1) var(--d, 0s) forwards;
  }

  @keyframes phIn {
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }

  .post-back {
    padding-top: 2rem;
    padding-bottom: 0;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8125rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    text-transform: lowercase;
    transition: color 0.2s ease;
  }

  .back-link:hover { color: var(--accent); }

  .post-header {
    padding: 2.5rem 0 3rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
    background: var(--bg-dark);
    position: relative;
    overflow: hidden;
  }

  .post-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 80% at 90% 50%, rgba(232, 74, 37, 0.15) 0%, transparent 65%),
      radial-gradient(ellipse 40% 50% at 0% 100%, rgba(29, 126, 240, 0.08) 0%, transparent 55%);
    pointer-events: none;
  }

  .post-header-inner {
    max-width: var(--content-width);
    position: relative;
    z-index: 1;
  }

  .post-meta-top {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .post-race {
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--accent);
    text-transform: lowercase;
    letter-spacing: 0.04em;
    font-style: italic;
  }

  .post-date {
    font-size: 0.75rem;
    color: var(--text-light-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 3.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--text-light);
    margin-bottom: 1.25rem;
  }

  .post-excerpt {
    font-size: 1.0625rem;
    color: var(--text-light-muted);
    line-height: 1.7;
    margin-bottom: 1.5rem;
    max-width: 56ch;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .post-tag {
    font-size: 0.6875rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-tint);
    border: 1px solid transparent;
    padding: 0.2em 0.6em;
  }

  .post-tag:nth-child(3n+2) {
    color: var(--blue);
    background: var(--blue-tint);
  }

  .post-tag:nth-child(3n+3) {
    color: var(--amber);
    background: var(--amber-tint);
  }

  .post-thumb {
    max-width: var(--content-width);
    margin-bottom: 2.5rem;
    border-radius: var(--radius, 4px);
    overflow: hidden;
  }

  .post-thumb img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    max-height: 480px;
  }

  .post-body {
    max-width: var(--content-width);
    padding-bottom: 6rem;
  }
</style>
