---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import StandingsWidget from '../components/StandingsWidget.astro';

const allPosts = await getCollection('posts');
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const [featuredPost, ...restPosts] = posts;
---

<BaseLayout
  title="the downforce blog"
  description="race analysis with actual opinions. f1 coverage that says something."
  showLoader
>
  <!-- Hero -->
  <section class="hero" id="hero">
    <div class="hero-grain" aria-hidden="true"></div>
    <div class="hero-cursor-glow" id="hero-glow" aria-hidden="true"></div>
    <div class="hero-streaks" aria-hidden="true">
      {Array.from({length:10}).map((_,i) => <div class="hero-streak" style={`--i:${i}`}></div>)}
    </div>

    <div class="container hero-inner">
      <div class="hero-accent-line" aria-hidden="true"></div>
      <h1 class="hero-title" aria-label="the downforce blog">
        <span class="ht-the hero-anim" style="--d:0.05s">the</span>
        <span class="ht-main" aria-hidden="true"><span class="hl" style="--i:0">d</span><span class="hl" style="--i:1">o</span><span class="hl" style="--i:2">w</span><span class="hl" style="--i:3">n</span><span class="hl" style="--i:4">f</span><span class="hl" style="--i:5">o</span><span class="hl" style="--i:6">r</span><span class="hl" style="--i:7">c</span><span class="hl" style="--i:8">e</span></span>
        <span class="ht-blog hero-anim" style="--d:0.6s">blog</span>
      </h1>
      <p class="hero-tagline hero-anim" style="--d:0.7s">race analysis.<br class="mobile-break" /> actual opinions.</p>
      <div class="hero-sub hero-anim" style="--d:0.82s">
        <span>formula one &amp; beyond</span>
        <span class="dot" aria-hidden="true">·</span>
        <span>no corporate hedging</span>
      </div>
      <a href="#posts" class="hero-cta hero-anim" id="hero-cta" style="--d:0.92s">read the latest →</a>
    </div>
    <div class="hero-scroll-hint" aria-hidden="true">
      <span>scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- Racing ticker -->
  <div class="race-ticker" aria-hidden="true">
    <div class="ticker-track">
      {[1,2].map(() => (
        <span class="ticker-inner">
          <span class="t-item">formula one</span><span class="t-sep">·</span>
          <span class="t-item">race analysis</span><span class="t-sep">·</span>
          <span class="t-item">no corporate hedging</span><span class="t-sep">·</span>
          <span class="t-item">actual opinions</span><span class="t-sep">·</span>
          <span class="t-item">f1 2025</span><span class="t-sep">·</span>
          <span class="t-item">driver standings</span><span class="t-sep">·</span>
          <span class="t-item">strategy calls</span><span class="t-sep">·</span>
          <span class="t-item">race reports</span><span class="t-sep">·</span>
          <span class="t-item">team dynamics</span><span class="t-sep">·</span>
          <span class="t-item">hot takes</span><span class="t-sep">·</span>
        </span>
      ))}
    </div>
  </div>

  <!-- Race photos strip (2×2) -->
  <section class="photo-strip" aria-label="Race photography">
    <div class="photo-item">
      <img src="/images/race1.jpg" alt="F1 cars battling through a corner" loading="eager" width="960" height="540" />
    </div>
    <div class="photo-item">
      <img src="/images/race2.jpg" alt="F1 cars racing under the lights" loading="eager" width="960" height="540" />
    </div>
    <div class="photo-item">
      <img src="/images/race3.jpg" alt="F1 action on track" loading="lazy" width="960" height="540" />
    </div>
    <div class="photo-item">
      <img src="/images/race4.jpg" alt="F1 racing at speed" loading="lazy" width="960" height="540" />
    </div>
  </section>

  <!-- Editorial statement -->
  <section class="editorial-band">
    <div class="container editorial-inner">
      <p class="editorial-quote">
        "this isn't a press release. it's a race report with a point of view."
      </p>
      <div class="editorial-pillars">
        <div class="pillar reveal-left" style="transition-delay:0s">
          <span class="pillar-icon">◆</span>
          <span class="pillar-label">race analysis</span>
          <span class="pillar-text">lap-by-lap breakdowns that go beyond the podium</span>
        </div>
        <div class="pillar reveal-left" style="transition-delay:0.1s">
          <span class="pillar-icon">◆</span>
          <span class="pillar-label">team dynamics</span>
          <span class="pillar-text">strategy calls, inter-team politics, and engineer decisions</span>
        </div>
        <div class="pillar reveal-left" style="transition-delay:0.2s">
          <span class="pillar-icon">◆</span>
          <span class="pillar-label">hot takes</span>
          <span class="pillar-text">opinions you won't find in the official press kits</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Posts grid -->
  <section class="posts-section" id="posts">
    <div class="container">
      <div class="section-header">
        <h2 class="section-label">latest</h2>
        <a href="/posts" class="see-all">all posts →</a>
      </div>

      {featuredPost && (
        <div class="featured-post reveal-on-scroll">
          <PostCard post={featuredPost} featured />
        </div>
      )}

      {restPosts.length > 0 && (
        <div class="posts-grid">
          {restPosts.map((post, i) => (
            <div class="reveal-on-scroll" style={`transition-delay: ${i * 0.08}s`}>
              <PostCard post={post} />
            </div>
          ))}
        </div>
      )}

      {posts.length === 0 && (
        <p class="no-posts">no posts yet. check back soon.</p>
      )}
    </div>
  </section>

  <!-- Live standings -->
  <StandingsWidget />

</BaseLayout>

<style>
  /* ─── hero ─── */
  .hero {
    min-height: calc(100svh - 56px);
    display: flex;
    align-items: center;
    padding-top: 56px;
    background: var(--bg-dark);
    color: var(--text-light);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(243,237,225,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(243,237,225,0.05) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 80% 50%, rgba(232, 74, 37, 0.12) 0%, transparent 70%),
      radial-gradient(ellipse 40% 60% at 10% 80%, rgba(29, 126, 240, 0.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    padding-top: 4rem;
    padding-bottom: 5rem;
  }

  .hero-accent-line {
    width: 0;
    height: 3px;
    background: var(--accent);
    margin-bottom: 2rem;
    animation: accentDraw 0.5s var(--ease-out-quint) 0.05s forwards;
  }

  @keyframes accentDraw {
    to { width: 40px; }
  }

  .hero-anim {
    opacity: 0;
    transform: translateY(20px);
    filter: blur(4px);
    animation: heroIn 0.65s var(--ease-out-quint) var(--d, 0s) forwards;
  }

  @keyframes heroIn {
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }

  /* ── letter-split title ── */
  .ht-the {
    display: block;
    font-size: clamp(1rem, 3vw, 1.8rem);
    font-weight: 400;
    letter-spacing: 0.22em;
    color: rgba(243,237,225,0.45);
    text-transform: lowercase;
    margin-bottom: 0.1em;
  }
  .ht-main { display: block; line-height: 0.9; }
  .ht-blog {
    display: block;
    font-size: clamp(1.6rem, 4.5vw, 3rem);
    font-weight: 400;
    font-style: italic;
    color: rgba(243,237,225,0.5);
    letter-spacing: 0.07em;
    margin-top: 0.15em;
  }
  .hl {
    display: inline-block;
    opacity: 0;
    transform: translateY(60px) rotateX(-80deg);
    animation: hlIn 0.55s var(--ease-out-quint) calc(0.15s + var(--i) * 0.05s) forwards;
  }
  @keyframes hlIn {
    to { opacity: 1; transform: translateY(0) rotateX(0); }
  }

  /* ── grain overlay ── */
  .hero-grain {
    position: absolute;
    inset: -20%;
    opacity: 0.028;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 180px 180px;
    pointer-events: none;
    animation: grainDrift 0.4s steps(1) infinite;
  }
  @keyframes grainDrift {
    0%  { transform: translate(0,0); }
    25% { transform: translate(-3%,-4%); }
    50% { transform: translate(4%, 2%); }
    75% { transform: translate(-2%, 5%); }
  }

  /* ── cursor glow ── */
  .hero-cursor-glow {
    position: absolute;
    width: 700px;
    height: 700px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(232,74,37,0.14) 0%, transparent 65%);
    pointer-events: none;
    transform: translate(-50%,-50%);
    top: 50%;
    left: 80%;
    transition: top 0.18s ease, left 0.18s ease;
    will-change: top, left;
  }

  /* ── racing streaks ── */
  .hero-streaks {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }
  .hero-streak {
    position: absolute;
    left: -20%;
    height: 1px;
    top: calc(8% + var(--i) * 8.5%);
    width: 0;
    background: linear-gradient(90deg, transparent, rgba(232,74,37,0.5) 30%, rgba(232,74,37,0.15) 70%, transparent);
    animation: streakIn 0.8s cubic-bezier(0.22,1,0.36,1) calc(0.25s + var(--i) * 0.055s) forwards;
  }
  @keyframes streakIn {
    to { width: 150%; }
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 12vw, 8rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--text-light);
    margin-bottom: 2rem;
  }

  .hero-tagline {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 4vw, 2.25rem);
    font-weight: 400;
    font-style: italic;
    color: var(--text-light-muted);
    letter-spacing: 0.01em;
    line-height: 1.3;
    margin-bottom: 1.5rem;
  }

  .mobile-break { display: none; }
  @media (max-width: 480px) { .mobile-break { display: inline; } }

  .hero-sub {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: rgba(243, 237, 225, 0.35);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 300;
    margin-bottom: 2.5rem;
  }

  .dot { color: var(--amber); }

  .hero-cta {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-light);
    border: 1px solid rgba(243, 237, 225, 0.3);
    padding: 0.65rem 1.5rem;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .hero-cta:hover {
    background: var(--accent);
    border-color: var(--accent);
  }

  .hero-scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: rgba(243, 237, 225, 0.25);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, rgba(243,237,225,0.3), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }

  /* ─── ticker ─── */
  .race-ticker {
    background: var(--accent);
    overflow: hidden;
    padding: 0.55rem 0;
    white-space: nowrap;
  }

  .ticker-track {
    display: inline-flex;
    animation: ticker 28s linear infinite;
  }

  .race-ticker:hover .ticker-track {
    animation-play-state: paused;
  }

  .ticker-inner {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    padding-right: 1rem;
  }

  .t-item {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(243,237,225,0.95);
  }

  .t-sep {
    color: rgba(243,237,225,0.4);
    font-size: 0.6rem;
  }

  @keyframes ticker {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* ─── photo strip ─── */
  .photo-strip {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 280px 280px;
    gap: 0;
    margin: 0;
    padding: 0;
    line-height: 0;
  }

  @media (max-width: 600px) {
    .photo-strip {
      grid-template-rows: 170px 170px;
    }
  }

  .photo-item {
    overflow: hidden;
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
  }

  .photo-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(0.85) saturate(0.85);
    transition: filter 0.4s ease;
  }

  .photo-item:hover img {
    filter: brightness(1) saturate(1);
  }

  /* ─── editorial band ─── */
  .editorial-band {
    background: var(--bg-dark);
    color: var(--text-light);
    padding: 4rem 0;
  }

  .editorial-inner {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .editorial-quote {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3.5vw, 2rem);
    font-style: italic;
    font-weight: 400;
    color: var(--text-light-muted);
    line-height: 1.4;
    max-width: 700px;
    border-left: 3px solid var(--accent);
    padding-left: 1.5rem;
  }

  .editorial-pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  @media (max-width: 640px) {
    .editorial-pillars { grid-template-columns: 1fr; gap: 1.5rem; }
  }

  .pillar {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .pillar-icon {
    font-size: 0.6rem;
  }

  .pillar:nth-child(1) .pillar-icon { color: var(--accent); }
  .pillar:nth-child(2) .pillar-icon { color: var(--amber); }
  .pillar:nth-child(3) .pillar-icon { color: var(--blue); }

  .pillar-label {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-light);
  }

  .pillar-text {
    font-size: 0.9375rem;
    color: var(--text-light-muted);
    line-height: 1.6;
    font-weight: 300;
  }

  /* ─── posts section ─── */
  .posts-section {
    padding: 4rem 0;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  .section-label {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .see-all {
    font-size: 0.9rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    transition: color 0.2s ease;
  }
  .see-all:hover { color: var(--accent); }

  .featured-post {
    margin-bottom: 1.5rem;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 480px), 1fr));
    gap: 1.5rem;
  }

  .no-posts {
    color: var(--text-muted);
    font-size: 1rem;
    font-style: italic;
  }
</style>

<script>
  // Cursor spotlight in hero
  const hero = document.getElementById('hero');
  const glow = document.getElementById('hero-glow');
  if (hero && glow) {
    hero.addEventListener('mousemove', e => {
      const r = hero.getBoundingClientRect();
      glow.style.left = (e.clientX - r.left) + 'px';
      glow.style.top  = (e.clientY - r.top)  + 'px';
    }, { passive: true });
  }

  // Photo strip parallax
  const photos = document.querySelectorAll<HTMLElement>('.photo-item img');
  const speeds = [0.03, 0.06, 0.04, 0.07];
  window.addEventListener('scroll', () => {
    photos.forEach((img, i) => {
      (img as HTMLElement).style.setProperty('--py', (window.scrollY * (speeds[i] ?? 0.05)).toFixed(1) + 'px');
    });
  }, { passive: true });

  // Magnetic CTA
  const cta = document.getElementById('hero-cta');
  if (cta) {
    cta.addEventListener('mousemove', e => {
      const r = cta.getBoundingClientRect();
      const x = ((e.clientX - r.left - r.width  / 2) * 0.3).toFixed(1);
      const y = ((e.clientY - r.top  - r.height / 2) * 0.3).toFixed(1);
      cta.style.transform = `translate(${x}px, ${y}px)`;
    });
    cta.addEventListener('mouseleave', () => { cta.style.transform = ''; });
  }
</script>
