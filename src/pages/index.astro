---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import StandingsWidget from '../components/StandingsWidget.astro';

const allPosts = await getCollection('posts');
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const [featuredPost, ...restPosts] = posts;
---

<BaseLayout
  title="the downforce blog"
  description="race analysis with actual opinions. f1 coverage that says something."
  showLoader
>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-accent-line" aria-hidden="true"></div>
      <h1 class="hero-title">the downforce<br />blog</h1>
      <p class="hero-tagline">race analysis.<br class="mobile-break" /> actual opinions.</p>
      <div class="hero-sub">
        <span>formula one &amp; beyond</span>
        <span class="dot" aria-hidden="true">·</span>
        <span>no corporate hedging</span>
      </div>
      <a href="#posts" class="hero-cta">read the latest →</a>
    </div>
    <div class="hero-scroll-hint" aria-hidden="true">
      <span>scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- Race photos strip (2×2) -->
  <section class="photo-strip" aria-label="Race photography">
    <div class="photo-item">
      <img src="/images/race1.jpg" alt="F1 cars battling through a corner" loading="eager" width="960" height="540" />
    </div>
    <div class="photo-item">
      <img src="/images/race2.jpg" alt="F1 cars racing under the lights" loading="eager" width="960" height="540" />
    </div>
    <div class="photo-item">
      <img src="/images/race3.jpg" alt="F1 action on track" loading="lazy" width="960" height="540" />
    </div>
    <div class="photo-item">
      <img src="/images/race4.jpg" alt="F1 racing at speed" loading="lazy" width="960" height="540" />
    </div>
  </section>

  <!-- Editorial statement -->
  <section class="editorial-band">
    <div class="container editorial-inner">
      <p class="editorial-quote">
        "this isn't a press release. it's a race report with a point of view."
      </p>
      <div class="editorial-pillars">
        <div class="pillar">
          <span class="pillar-icon">◆</span>
          <span class="pillar-label">race analysis</span>
          <span class="pillar-text">lap-by-lap breakdowns that go beyond the podium</span>
        </div>
        <div class="pillar">
          <span class="pillar-icon">◆</span>
          <span class="pillar-label">team dynamics</span>
          <span class="pillar-text">strategy calls, inter-team politics, and engineer decisions</span>
        </div>
        <div class="pillar">
          <span class="pillar-icon">◆</span>
          <span class="pillar-label">hot takes</span>
          <span class="pillar-text">opinions you won't find in the official press kits</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Posts grid -->
  <section class="posts-section" id="posts">
    <div class="container">
      <div class="section-header">
        <h2 class="section-label">latest</h2>
        <a href="/posts" class="see-all">all posts →</a>
      </div>

      {featuredPost && (
        <div class="featured-post reveal-on-scroll">
          <PostCard post={featuredPost} featured />
        </div>
      )}

      {restPosts.length > 0 && (
        <div class="posts-grid">
          {restPosts.map((post, i) => (
            <div class="reveal-on-scroll" style={`transition-delay: ${i * 0.08}s`}>
              <PostCard post={post} />
            </div>
          ))}
        </div>
      )}

      {posts.length === 0 && (
        <p class="no-posts">no posts yet. check back soon.</p>
      )}
    </div>
  </section>

  <!-- Live standings -->
  <StandingsWidget />

</BaseLayout>

<style>
  /* ─── hero ─── */
  .hero {
    min-height: calc(100svh - 56px);
    display: flex;
    align-items: center;
    padding-top: 56px;
    background: var(--bg-dark);
    color: var(--text-light);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(243,237,225,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(243,237,225,0.03) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    padding-top: 4rem;
    padding-bottom: 5rem;
  }

  .hero-accent-line {
    width: 40px;
    height: 3px;
    background: var(--accent);
    margin-bottom: 2rem;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 12vw, 8rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--text-light);
    margin-bottom: 2rem;
  }

  .hero-tagline {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 4vw, 2.25rem);
    font-weight: 400;
    font-style: italic;
    color: var(--text-light-muted);
    letter-spacing: 0.01em;
    line-height: 1.3;
    margin-bottom: 1.5rem;
  }

  .mobile-break { display: none; }
  @media (max-width: 480px) { .mobile-break { display: inline; } }

  .hero-sub {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: rgba(243, 237, 225, 0.35);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 300;
    margin-bottom: 2.5rem;
  }

  .dot { color: var(--amber); }

  .hero-cta {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-light);
    border: 1px solid rgba(243, 237, 225, 0.3);
    padding: 0.65rem 1.5rem;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .hero-cta:hover {
    background: var(--accent);
    border-color: var(--accent);
  }

  .hero-scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: rgba(243, 237, 225, 0.25);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, rgba(243,237,225,0.3), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }

  /* ─── photo strip ─── */
  .photo-strip {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    height: 560px;
  }

  @media (max-width: 600px) {
    .photo-strip {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 1fr 1fr;
      height: 340px;
    }
  }

  .photo-item {
    overflow: hidden;
    position: relative;
  }

  .photo-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s var(--ease-out-quint), filter 0.4s ease;
    filter: brightness(0.85) saturate(0.85);
  }

  .photo-item:hover img {
    transform: scale(1.04);
    filter: brightness(1) saturate(1);
  }

  /* ─── editorial band ─── */
  .editorial-band {
    background: var(--bg-dark);
    color: var(--text-light);
    padding: 4rem 0;
  }

  .editorial-inner {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .editorial-quote {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3.5vw, 2rem);
    font-style: italic;
    font-weight: 400;
    color: var(--text-light-muted);
    line-height: 1.4;
    max-width: 700px;
    border-left: 3px solid var(--accent);
    padding-left: 1.5rem;
  }

  .editorial-pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  @media (max-width: 640px) {
    .editorial-pillars { grid-template-columns: 1fr; gap: 1.5rem; }
  }

  .pillar {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .pillar-icon {
    color: var(--accent);
    font-size: 0.6rem;
  }

  .pillar-label {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-light);
  }

  .pillar-text {
    font-size: 0.9375rem;
    color: var(--text-light-muted);
    line-height: 1.6;
    font-weight: 300;
  }

  /* ─── posts section ─── */
  .posts-section {
    padding: 4rem 0;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  .section-label {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .see-all {
    font-size: 0.9rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    transition: color 0.2s ease;
  }
  .see-all:hover { color: var(--accent); }

  .featured-post {
    margin-bottom: 1.5rem;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 480px), 1fr));
    gap: 1.5rem;
  }

  .no-posts {
    color: var(--text-muted);
    font-size: 1rem;
    font-style: italic;
  }
</style>
