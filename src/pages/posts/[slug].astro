---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, date, excerpt, tags, race, thumbnail } = post.data;

const thumbGlob = import.meta.glob('/public/images/posts/*.*', { eager: true });
const thumbByName: Record<string, string> = {};
for (const path of Object.keys(thumbGlob)) {
  const file = path.split('/').pop()!;
  const name = file.replace(/\.[^.]+$/, '');
  thumbByName[name] = path.replace('/public', '');
}
const allPosts = await getCollection('posts');
const sortedAsc = allPosts.sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
const articleIndex = sortedAsc.findIndex(p => p.id === post.id);
const autoThumb = articleIndex >= 0 ? (thumbByName[`article${articleIndex + 1}`] ?? null) : null;
const resolvedThumb = thumbnail || autoThumb || undefined;
---

<PostLayout
  title={title}
  date={date}
  excerpt={excerpt}
  tags={tags}
  race={race}
  thumbnail={resolvedThumb}
>
  <Content />
</PostLayout>
